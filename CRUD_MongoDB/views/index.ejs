<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
<div class="w-full min-h-screen bg-zinc-900 text-white flex flex-col">

    <div class="w-full px-6 py-4 border-b border-zinc-800">
        <a href="/read" class="text-zinc-400 hover:text-white transition-colors text-sm font-medium">
            Read
        </a>
    </div>
    <div class="p-6 sm:p-10 max-w-4xl w-full">
        
        <h1 class="text-3xl font-semibold tracking-tighter mb-8">
            Create User
        </h1>

        <form class="grid grid-cols-1 sm:grid-cols-2 gap-5 max-w-2xl">

            <div class="flex flex-col gap-1">
                <label class="text-xs text-zinc-400 font-medium">Name</label>
                <input
                    class="w-full px-4 py-3 bg-zinc-800/50 focus:bg-transparent border border-zinc-700 rounded-lg outline-none focus:border-blue-500 transition-all"
                    type="text"
                    placeholder="Enter name"
                >
            </div>

            <div class="flex flex-col gap-1">
                <label class="text-xs text-zinc-400 font-medium">Email</label>
                <input
                    class="w-full px-4 py-3 bg-zinc-800/50 focus:bg-transparent border border-zinc-700 rounded-lg outline-none focus:border-blue-500 transition-all"
                    type="email"
                    placeholder="Enter email"
                >
            </div>

            <div class="flex flex-col gap-1 sm:col-span-2">
                <label class="text-xs text-zinc-400 font-medium">Image URL</label>
                <input
                    class="w-full px-4 py-3 bg-zinc-800/50 focus:bg-transparent border border-zinc-700 rounded-lg outline-none focus:border-blue-500 transition-all"
                    type="text"
                    placeholder="https://example.com/image.jpg"
                >
            </div>

            <div class="pt-2 sm:col-span-2">
                <input
                    class="w-full sm:w-auto px-6 py-3 bg-blue-600 hover:bg-blue-500 font-medium rounded-lg cursor-pointer transition-colors"
                    type="submit"
                    value="Create User"
                >
            </div>

        </form>
    </div>

</div>

</div>
</div>
</body>
</html>
