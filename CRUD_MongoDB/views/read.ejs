<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
<div class="w-full min-h-screen bg-zinc-900 text-white flex flex-col">

    <div class="w-full px-6 py-4 border-b border-zinc-800 bg-zinc-900">
        <a href="/" class="text-zinc-400 hover:text-white transition-colors text-sm font-medium">
            Back to Home
        </a>
    </div>

    <div class="w-full p-6 sm:p-10">
        <h1 class="text-3xl font-semibold tracking-tighter mb-8">All Users</h1>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">

            <% if(user.length > 0){ %>

                <% user.forEach(function(user){ %>
                <div class="bg-zinc-800/60 border border-zinc-800/80 p-4 rounded-xl flex flex-col justify-between">
                    <div>
                        <div class="w-full h-72 rounded-lg bg-zinc-700 object-cover overflow-hidden">
                            <img class="w-full h-full object-cover object-center" src="<%= user.image %>" alt="">
                        </div>
                        <h3 class="text-xl font-medium mt-4 tracking-tighter">
                            <%= user.name %>
                        </h3>
                        
                        <h5 class="text-zinc-400 text-sm mt-1">
                            <%= user.email %>
                        </h5>
                        </h5>
                    </div>
                    
                    <div class="flex items-center gap-5 mt-6 pt-4 border-t border-zinc-700/50 text-sm font-medium">
                        <a class="text-zinc-300 hover:text-white transition-colors" href="/edit/<%= user.id %>">Edit User</a>
                        <a class="text-red-400 hover:text-red-500 transition-colors" href="/delete/<%= user._id %>">Delete User</a>
                    </div>
                </div>
          <%  }) %>

           <% } else { %>

            <h3 class="text-zinc-500">No Users Yet</h3>

            <% } %>

        </div>
    </div>

</div>
</body>
</html>
